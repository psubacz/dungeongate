# .gitignore for dungeongate microservices

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
build/
dist/

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Application specific
*.log
*.pid
*.seed
*.pid.lock

# Database files
*.db
*.sqlite
*.sqlite3

# Configuration files with secrets
*.secret.yaml
*.secret.yml
*secret.env

# TTY recordings
*.ttyrec

# SSH keys
ssh_host_*
*.pem
*.key
!*.key.example

# Docker
.docker/

# Kubernetes
*.kubeconfig

# Temporary files
tmp/
temp/
.tmp/

# Legacy files (keep tracked but ignore changes)
configs/legacy/

# Build artifacts
*.tar.gz
*.zip
*.deb
*.rpm

# Logs
logs/
*.log

# Environment files
.env
.env.local
.env.*.local

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# Dependency directories
node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Service specific
auth-service
user-service
game-service
session-service
nethack-kuberentes/*

# Helm charts
charts/*/charts/
charts/*/requirements.lock

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Vagrant
.vagrant/

scripts/debug/*
# Development files
test-data/
data/
.env
*.log

# SSH keys
ssh_host_*
*.pem
*.key
!*.key.example

# Database files
*.db
*.db-*
